            "users",
            "search"
          ],
          "query": [
            {
              "key": "q",
              "value": "{{search_term}}"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "role",
              "value": "creator",
              "disabled": true
            },
            {
              "key": "status",
              "value": "suspended",
              "disabled": true
            }
          ]
        }
      }
    },
