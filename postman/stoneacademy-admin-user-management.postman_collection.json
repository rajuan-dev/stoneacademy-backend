    "name": "StoneAcademy Admin User Management",
    "description": "Admin endpoints covering paginated user list, search, block/unblock, and detail views for dashboard features.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin - List Users (Paginated)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/admin/users?page={{page}}&limit={{limit}}&search={{search_term}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "{{page}}"
            },
            {
              "key": "limit",
              "value": "{{limit}}"
            },
            {
              "key": "search",
              "value": "{{search_term}}"
            },
            {
              "key": "role",
              "value": "creator",
              "disabled": true
            },
            {
              "key": "status",
              "value": "active",
              "disabled": true
            }
          ]
        }
      }
    },
    {
      "name": "Admin - Search Users by Name/Email/Username",
      "request": {
        "method": "GET",
