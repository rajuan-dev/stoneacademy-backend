  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register User With Country",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"confirmPassword\": \"{{userPassword}}\",\n  \"fullName\": \"{{userFullName}}\",\n  \"country\": \"{{country}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Verify Registration OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"purpose\": \"verify_email\",\n  \"code\": \"{{otpCode}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/otp/verify"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('login succeeded', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "pm.collectionVariables.set('userToken', res.data.accessToken);",
                  "pm.collectionVariables.set('creatorUserId', res.data.user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "auth": {
            "type": "noauth"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('admin login succeeded', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "pm.collectionVariables.set('adminToken', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/admin/login"
          }
        }
      ]
    },
    {
      "name": "2. Profile Geography",
      "item": [
        {
          "name": "Get My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res?.data?._id) pm.collectionVariables.set('creatorUserId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update My State And City",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('profile keeps geography', function () {",
                  "  pm.expect(res.data.country).to.eql(pm.collectionVariables.get('country'));",
                  "  pm.expect(res.data.state).to.eql(pm.collectionVariables.get('state'));",
                  "  pm.expect(res.data.city).to.eql(pm.collectionVariables.get('city'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"{{country}}\",\n  \"state\": \"{{state}}\",\n  \"city\": \"{{city}}\"\n}"
            },
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    },
