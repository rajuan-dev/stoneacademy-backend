{
  "info": {
    "_postman_id": "c2f5c4f4-8cb9-4627-bdc7-2c326be8ca54",
    "name": "StoneAcademy - Full Activity/Event Flow",
    "description": "Dedicated collection for full flow: activity/event details, join, pass+QR, host profile, rating with quick tags, Stripe checkout intent, and paid event join.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5191/api/v1"
    },
    {
      "key": "email",
      "value": "john@example.com"
    },
    {
      "key": "password",
      "value": "Password123!"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "activityId",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "paidEventId",
      "value": ""
    },
    {
      "key": "hostUserId",
      "value": ""
    },
    {
      "key": "paymentIntentId",
      "value": ""
    },
    {
      "key": "providerReference",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Save accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.data?.accessToken;",
                  "if (token) pm.collectionVariables.set('accessToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Activity Flow",
      "item": [
        {
          "name": "Get Activity Details (Save hostUserId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const hostUserId = res?.data?.host?.id;",
                  "if (hostUserId) pm.collectionVariables.set('hostUserId', hostUserId);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/activities/{{activityId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "activities",
                "{{activityId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Join Activity",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/activities/{{activityId}}/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "activities",
                "{{activityId}}",
                "join"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Activity Pass + QR",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/activities/{{activityId}}/pass",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "activities",
                "{{activityId}}",
                "pass"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Event Flow (Free)",
      "item": [
        {
          "name": "Get Event Details (Save hostUserId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const hostUserId = res?.data?.host?.id;",
                  "if (hostUserId) pm.collectionVariables.set('hostUserId', hostUserId);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{eventId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Join Event (Free)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{eventId}}",
                "join"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Event Pass + QR",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/pass",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{eventId}}",
                "pass"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Event Flow (Paid + Stripe)",
      "item": [
        {
          "name": "Get Paid Event Details (Price/Gallery)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const hostUserId = res?.data?.host?.id;",
                  "if (hostUserId) pm.collectionVariables.set('hostUserId', hostUserId);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events/{{paidEventId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{paidEventId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Stripe Checkout Intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const paymentIntentId = res?.data?.paymentIntentId;",
                  "if (paymentIntentId) {",
                  "  pm.collectionVariables.set('paymentIntentId', paymentIntentId);",
                  "  pm.collectionVariables.set('providerReference', paymentIntentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/billing/events/{{paidEventId}}/checkout-intent",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "events",
                "{{paidEventId}}",
                "checkout-intent"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Join Paid Event (After Stripe Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerReference\": \"{{providerReference}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{paidEventId}}/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{paidEventId}}",
                "join"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Paid Event Pass + QR",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events/{{paidEventId}}/pass",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{paidEventId}}",
                "pass"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Host Profile + Ratings",
      "item": [
        {
          "name": "Get Host Profile (Photo/Gallery/Ratings/Comments)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{hostUserId}}/host-profile?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{hostUserId}}",
                "host-profile"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Rate Activity Host (Quick Tags)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetType\": \"activity\",\n  \"targetId\": \"{{activityId}}\",\n  \"rating\": 5,\n  \"tags\": [\"friendly\", \"ontime\", \"motivating\", \"professional\"],\n  \"comment\": \"Great host and very positive experience\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reviews"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Rate Event Host (Quick Tags)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetType\": \"event\",\n  \"targetId\": \"{{eventId}}\",\n  \"rating\": 4,\n  \"tags\": [\"friendly\", \"professional\"],\n  \"comment\": \"Good organization\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reviews"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Reviews of Host",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reviews?targetUserId={{hostUserId}}&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reviews"
              ],
              "query": [
                {
                  "key": "targetUserId",
                  "value": "{{hostUserId}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
