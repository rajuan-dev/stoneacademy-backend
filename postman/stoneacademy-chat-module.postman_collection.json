    {
      "name": "List My Threads",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/chat/threads",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Thread Messages",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/chat/threads/{{threadId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "{{threadId}}",
            "messages"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Send Text Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"text\",\n  \"text\": \"Hello from Postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat/threads/{{threadId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "{{threadId}}",
            "messages"
          ]
        }
      },
      "response": []
    },
    {
