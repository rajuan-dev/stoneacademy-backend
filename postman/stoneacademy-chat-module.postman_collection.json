            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"image\",\n  \"imageUrl\": \"https://images.unsplash.com/photo-1520975922323-47f564f2e4a5\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat/threads/{{threadId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "{{threadId}}",
            "messages"
          ]
        }
      },
      "response": []
