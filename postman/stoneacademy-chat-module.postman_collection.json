{
  "info": {
    "_postman_id": "0f31e8d1-79df-42c7-9a45-c130d85d9d98",
    "name": "StoneAcademy - Chat Module (Host/Admin Flow)",
    "description": "Minimal chat flow: host/admin thread, send messages, list messages, seen/unseen.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5191/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "activityId",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "hostUserId",
      "value": ""
    },
    {
      "key": "threadId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Host Thread (Auto detect by targetId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "const id = res?.data?._id;",
              "if (id) pm.collectionVariables.set('threadId', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetId\": \"{{activityId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat/threads/host",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "host"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Host Thread (Auto detect by eventId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "const id = res?.data?._id;",
              "if (id) pm.collectionVariables.set('threadId', id);"
            ]
