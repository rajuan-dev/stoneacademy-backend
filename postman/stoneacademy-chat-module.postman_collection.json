          "mode": "raw",
          "raw": "{\n  \"targetId\": \"{{eventId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat/threads/host",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "host"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Host Thread (Direct by hostUserId)",
      "event": [
        {
