            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "const id = res?.data?._id;",
              "if (id) pm.collectionVariables.set('threadId', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"hostUserId\": \"{{hostUserId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat/threads/host",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
            "threads",
            "host"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Admin Thread",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "const id = res?.data?._id;",
              "if (id) pm.collectionVariables.set('threadId', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/chat/threads/admin",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat",
