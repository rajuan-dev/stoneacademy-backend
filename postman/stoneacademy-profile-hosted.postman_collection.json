{
  "info": {
    "_postman_id": "e4ec2cf0-1e75-4f08-a1c7-0864bbde4b0d",
    "name": "StoneAcademy Profile Hosted Content",
    "description": "Endpoints that allow a logged-in user to review activities and events they have hosted.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "My Hosted Activities",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{user_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/me/hosted/activities?page={{page}}&limit={{limit}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "me",
            "hosted",
            "activities"
          ],
          "query": [
            {
              "key": "page",
              "value": "{{page}}"
            },
            {
              "key": "limit",
              "value": "{{limit}}"
            }
          ]
        }
      }
    },
    {
      "name": "My Hosted Events",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{user_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/me/hosted/events?page={{page}}&limit={{limit}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "me",
            "hosted",
            "events"
          ],
          "query": [
            {
              "key": "page",
              "value": "{{page}}"
            },
            {
              "key": "limit",
              "value": "{{limit}}"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5191/api/v1"
    },
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "page",
      "value": "1"
    },
    {
      "key": "limit",
      "value": "10"
    }
  ]
}
