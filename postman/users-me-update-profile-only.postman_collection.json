{
  "info": {
    "name": "Users Me - Update Profile",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Single route collection for PATCH /users/me (update profile fields and photo in same request)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5191/api/v1" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "PATCH /users/me (fields + photo)",
      "request": {
        "method": "PATCH",
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{accessToken}}", "type": "string" }
          ]
        },
        "url": "{{baseUrl}}/users/me",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "fullName", "value": "John Smith", "type": "text" },
            { "key": "phoneNumber", "value": "+1234567890", "type": "text" },
            { "key": "dob", "value": "1997-11-28", "type": "text" },
            { "key": "gender", "value": "female", "type": "text" },
            { "key": "location", "value": "{\"label\":\"San Francisco, CA\"}", "type": "text" },
            { "key": "photo", "type": "file" }
          ]
        }
      }
    }
  ]
}
