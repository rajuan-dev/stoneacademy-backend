{
  "info": {
    "name": "Stoneacademy API - User",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "User-facing endpoints for Stoneacademy backend."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "activityId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "mediaId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"StrongP@ssw0rd\",\n  \"confirmPassword\": \"StrongP@ssw0rd\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
            }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/otp/send",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"purpose\": \"verify_email\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/otp/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"purpose\": \"verify_email\",\n  \"code\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "Password Forgot",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/password/forgot",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            }
          }
        },
        {
          "name": "Password Reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/password/reset",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"code\": \"1234\",\n  \"newPassword\": \"StrongP@ssw0rd\"\n}"
            }
          }
        },
        {
          "name": "Token Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/token/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"StrongP@ssw0rd\",\n  \"newPassword\": \"StrongP@ssw0rd1\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated User\",\n  \"phone\": \"+1-555-123-4567\"\n}"
            }
          }
        },
        {
          "name": "Upload Profile Photo",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/me/profile-photo",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "photo", "type": "file" }]
            }
          }
        },
        {
          "name": "Upload Gallery",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/me/gallery",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "media", "type": "file" }]
            }
          }
        },
        {
          "name": "Remove Gallery Item",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/me/gallery/{{mediaId}}"
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/public"
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/{{userId}}/block"
          }
        },
        {
          "name": "Unblock User",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/users/{{userId}}/block"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Activities",
      "item": [
        {
          "name": "List Activities",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/activities"
          }
        },
        {
          "name": "Create Activity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning Run\",\n  \"typeCategoryId\": \"{{categoryId}}\",\n  \"description\": \"Group run\",\n  \"startAt\": \"2026-02-10T09:00:00.000Z\",\n  \"participantLimit\": 10\n}"
            }
          }
        },
        {
          "name": "Get Activity",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/activities/{{activityId}}"
          }
        },
        {
          "name": "Update Activity",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning Run Updated\"\n}"
            }
          }
        },
        {
          "name": "Cancel Activity (DELETE)",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}"
          }
        },
        {
          "name": "Join Activity",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}/join"
          }
        },
        {
          "name": "Leave Activity",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}/leave"
          }
        },
        {
          "name": "Get Activity Pass",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}/pass"
          }
        },
        {
          "name": "Cancel Activity (POST)",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "url": "{{baseUrl}}/activities/{{activityId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Misc",
      "item": [
        {
          "name": "Billing (Placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/billing"
          }
        },
        {
          "name": "Services (Placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services"
          }
        },
        {
          "name": "Reports (Placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports"
          }
        },
        {
          "name": "Reviews (Placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews"
          }
        },
        {
          "name": "Quotes (Placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quotes"
          }
        }
      ]
    }
  ]
}
