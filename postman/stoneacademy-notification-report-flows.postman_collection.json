              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"warn\",\n  \"note\": \"Repeated complaints were confirmed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/reports/{{reportId}}/action",
