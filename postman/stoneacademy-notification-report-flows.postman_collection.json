        },
        {
          "name": "Update Activity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Activity Title\",\n  \"description\": \"Updated schedule and instructions.\",\n  \"participantLimit\": 40\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/activities/{{activityId}}",
              "host": ["{{baseUrl}}"],
              "path": ["activities", "{{activityId}}"]
