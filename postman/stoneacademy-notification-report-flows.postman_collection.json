            "url": {
              "raw": "{{baseUrl}}/admin/reports?page=1&limit=20&entityType=activity&status=open",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "entityType", "value": "activity" },
                { "key": "status", "value": "open" }
              ]
            }
          }
