            "url": {
              "raw": "{{baseUrl}}/activities/{{activityId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["activities", "{{activityId}}", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Event Flows",
      "item": [
        {
          "name": "Join Event",
          "request": {
