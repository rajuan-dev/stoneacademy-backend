            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerReference\": \"pi_test_successful_payment_reference\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/join",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "join"]
