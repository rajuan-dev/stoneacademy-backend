            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "User Reports",
      "item": [
        {
          "name": "Report Activity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entityType\": \"activity\",\n  \"entityId\": \"{{activityId}}\",\n  \"reason\": \"inappropriate_content\",\n  \"details\": \"The activity details contain misleading or inappropriate instructions.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          }
        },
        {
          "name": "Report Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entityType\": \"event\",\n  \"entityId\": \"{{eventId}}\",\n  \"reason\": \"other\",\n  \"details\": \"The organizer changed the details and pricing in a suspicious way.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          }
        },
        {
          "name": "List My Reports",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/mine?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "mine"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get My Report Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reports/{{reportId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "{{reportId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Reports & Admin Notifications",
